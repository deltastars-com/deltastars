# =====================================================
# Netlify Configuration - الإعدادات النهائية
# =====================================================

[build]
  command = "npm run build"
  publish = "dist"

[build.environment]
  NODE_VERSION = "18"
  NPM_VERSION = "9"

# =====================================================
# تثبيت الـ Plugin المخصص
# =====================================================
[[plugins]]
  package = "./netlify-plugin-ai-validator.js"

# =====================================================
# إعدادات المعالجة
# =====================================================
[processing]
  skip_processing = false
  css = {}
  html = {}
  images = {}
  js = {}

# =====================================================
# إعدادات التحليلات (اختياري)
# =====================================================
[analytics]
  enabled = false

# =====================================================
# إعدادات إعادة التوجيه (اختياري)
# =====================================================
# [[redirects]]
#   from = "/*"
#   to = "/index.html"
#   status = 200
